generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lodge {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  members    Member[]
  accounts   Account[]
  payments   Payment[]
  auditLogs  AuditLog[]
  rites      Rite[]
  powers     Power[]
  invoices   Invoice[]
  subscription Subscription?
  sessions   Session[]
  terms      Term[]
  offices    Office[]
  cashCloses CashClose[]
  attendances   Attendance[]
  memberOffices MemberOffice[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("admin")
  lodgeId       String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lodge         Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  auditLogs     AuditLog[]
}

model Member {
  id            String   @id @default(cuid())
  lodgeId       String
  name          String
  email         String?
  phone         String?
  status        String   @default("active")
  riteId        String?
  powerId       String?
  gradeName     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lodge         Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  rite          Rite?    @relation(fields: [riteId], references: [id], onDelete: SetNull)
  power         Power?   @relation(fields: [powerId], references: [id], onDelete: SetNull)
  accounts      Account[]
  payments      Payment[]
  invoices      Invoice[]
  attendances   Attendance[]
  memberOffices MemberOffice[]
}

model Account {
  id           String   @id @default(cuid())
  lodgeId      String
  memberId     String?
  type         String   // RECEIVABLE | PAYABLE
  title        String
  amount       Float
  dueDate      DateTime
  status       String   @default("pending")
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  payments     Payment[]
  invoices     Invoice[]
}

model Invoice {
  id                 String   @id @default(cuid())
  lodgeId            String
  accountId          String
  memberId           String?
  number             String
  status             String   @default("pending")
  issuedAt           DateTime @default(now())
  dueDate            DateTime
  amount             Float
  description        String?
  isRecurring        Boolean  @default(false)
  recurringInterval  String?
  recurringCount     Int?
  nextDueDate        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lodge              Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member             Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model Payment {
  id           String   @id @default(cuid())
  lodgeId      String
  accountId    String
  memberId     String?
  amount       Float
  paidAt       DateTime @default(now())
  method       String   @default("manual")
  note         String?

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model Subscription {
  id              String   @id @default(cuid())
  lodgeId         String   @unique
  stripeSubscriptionId String? @unique
  stripeCustomerId String?
  plan            String   @default("oficina")
  status          String   @default("inactive")
  memberCount     Int      @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lodge           Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  lodgeId      String
  userId       String?
  action       String
  entity       String
  entityId     String
  before       String?
  after        String?
  createdAt    DateTime @default(now())

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Session {
  id        String   @id @default(cuid())
  lodgeId   String
  title     String
  date      DateTime
  type      String   @default("ordinary")
  grade     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge      Lodge       @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  lodgeId   String
  sessionId String
  memberId  String
  status    String   @default("present")
  notes     String?
  createdAt DateTime @default(now())

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([lodgeId])
}

model Office {
  id        String   @id @default(cuid())
  lodgeId   String
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge        Lodge          @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  memberOffices MemberOffice[]
}

model Term {
  id        String   @id @default(cuid())
  lodgeId   String
  title     String
  startDate DateTime
  endDate   DateTime?
  status    String   @default("active")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge        Lodge          @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  memberOffices MemberOffice[]
  cashCloses   CashClose[]
}

model MemberOffice {
  id        String   @id @default(cuid())
  lodgeId   String
  memberId  String
  officeId  String
  termId    String
  createdAt DateTime @default(now())

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  office    Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([memberId, officeId, termId])
  @@index([lodgeId])
}

model CashClose {
  id          String   @id @default(cuid())
  lodgeId     String
  termId      String
  closedAt    DateTime @default(now())
  totalReceivables Float  @default(0)
  totalPayables    Float  @default(0)
  totalPayments    Float  @default(0)
  netBalance       Float  @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  lodge       Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([lodgeId, termId])
}

model Rite {
  id        String   @id @default(cuid())
  lodgeId   String
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  members   Member[]
}

model Power {
  id        String   @id @default(cuid())
  lodgeId   String
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  members   Member[]
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lodge {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active")
  // Dados comerciais (loja = PJ sem fins lucrativos com CNPJ)
  legalName    String?  // Razão Social
  tradeName    String?  // Nome Fantasia
  cnpj         String?
  email        String?
  phone        String?
  addressLine  String?
  addressNumber String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  // Dados bancários
  bankName     String?
  bankAgency   String?
  bankAccount  String?
  pixKey       String?
  // Identidade maçônica (escolhida no onboarding / editável nas configurações)
  riteName     String?  // rito praticado (define os cargos da loja)
  powerName    String?  // potência / obediência à qual a loja é filiada
  // Agenda padrão de sessões
  sessionWeekdays  String?  // dias da semana: índices 0=Dom..6=Sáb separados por vírgula (ex.: "2,4")
  sessionFrequency String?  @default("weekly") // weekly | biweekly | monthly
  // Asaas (BYO-key): cada loja conecta a própria conta. Chave criptografada (AES-256-GCM).
  asaasApiKeyEnc    String?
  asaasEnv          String?  @default("sandbox") // sandbox | production
  asaasWebhookToken String?  // token p/ validar o webhook do Asaas desta loja
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  members       Member[]
  accounts      Account[]
  payments      Payment[]
  auditLogs     AuditLog[]
  rites         Rite[]
  powers        Power[]
  invoices      Invoice[]
  subscription  Subscription?
  sessions      Session[]
  terms         Term[]
  offices       Office[]
  cashCloses    CashClose[]
  attendances   Attendance[]
  memberOffices MemberOffice[]
  documents     Document[]
  messageLogs   MessageLog[]
  chartAccounts ChartAccount[]
  rolePermissions RolePermission[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("admin")
  lodgeId       String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lodge         Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  auditLogs     AuditLog[]
}

model Member {
  id                 String   @id @default(cuid())
  lodgeId            String
  name               String
  email              String?
  phone              String?
  status             String   @default("active")
  riteId             String?
  powerId            String?
  gradeName          String?
  birthDate          DateTime?
  cpf                String?
  rg                 String?
  maritalStatus      String?
  spouseName         String?
  spouseBirthDate    DateTime?
  childrenNames      String?
  fatherName         String?
  motherName         String?
  occupation         String?
  nationality        String?
  addressLine        String?
  addressNumber      String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  zipCode            String?
  country            String?
  initiationDate     DateTime?
  elevationDate      DateTime?
  exaltationDate     DateTime?
  installationDate   DateTime?
  initiationLodge    String?
  elevationLodge     String?
  exaltationLodge    String?
  installationLodge  String?
  initiationDegree   String?
  currentDegree      String?
  originLodge        String?
  masonicNumber      String?
  documents          String?
  notes              String?
  asaasCustomerId    String?  // id do cliente no Asaas da loja (evita recriar a cada cobrança)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lodge              Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  rite               Rite?    @relation(fields: [riteId], references: [id], onDelete: SetNull)
  power              Power?   @relation(fields: [powerId], references: [id], onDelete: SetNull)
  accounts           Account[]
  payments           Payment[]
  invoices           Invoice[]
  attendances        Attendance[]
  memberOffices      MemberOffice[]
  documentsList      Document[]
  messageLogs        MessageLog[]
}

model Document {
  id           String   @id @default(cuid())
  lodgeId      String
  memberId     String
  title        String
  kind         String   @default("document")
  category     String?  @default("general")
  status       String?  @default("draft")
  storageKey   String?
  fileName     String?
  fileUrl      String?
  mimeType     String?
  content      String?
  checksum     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model MessageLog {
  id        String   @id @default(cuid())
  lodgeId   String
  memberId  String?
  channel   String
  title     String
  content   String
  status    String   @default("queued")
  createdAt DateTime @default(now())

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model Account {
  id             String   @id @default(cuid())
  lodgeId        String
  memberId       String?
  chartAccountId String?  // vínculo ao plano de contas (livro caixa / balancete)
  type           String   // RECEIVABLE | PAYABLE
  title          String
  amount         Float
  dueDate        DateTime
  status         String   @default("pending")
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lodge        Lodge        @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member       Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  chartAccount ChartAccount? @relation(fields: [chartAccountId], references: [id], onDelete: SetNull)
  payments     Payment[]
  invoices     Invoice[]
}

model Invoice {
  id                 String   @id @default(cuid())
  lodgeId            String
  accountId          String
  memberId           String?
  number             String
  status             String   @default("pending")
  issuedAt           DateTime @default(now())
  dueDate            DateTime
  amount             Float
  description        String?
  isRecurring        Boolean  @default(false)
  recurringInterval  String?
  recurringCount     Int?
  nextDueDate        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lodge              Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member             Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model Payment {
  id           String   @id @default(cuid())
  lodgeId      String
  accountId    String
  memberId     String?
  amount       Float
  paidAt       DateTime @default(now())
  method       String   @default("manual")
  note         String?

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model Subscription {
  id              String   @id @default(cuid())
  lodgeId         String   @unique
  stripeSubscriptionId String? @unique
  stripeCustomerId String?
  stripeScheduleId String?  // schedule de downgrade agendado (Stripe)
  plan            String   @default("oficina")
  // status: trialing | active | past_due | inactive | canceled
  status          String   @default("inactive")
  billingInterval String   @default("month") // month | year
  paymentMethod   String?  // card | pix | boleto
  trialEndsAt     DateTime?
  // Downgrade agendado para o fim do período vigente (sem reembolso)
  pendingPlan     String?
  pendingPlanEffectiveAt DateTime?
  memberCount     Int      @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lodge           Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
}

// Convite de acesso (cadastro de teste somente por convite).
model Invitation {
  id          String   @id @default(cuid())
  code        String   @unique
  email       String?  // opcional: convite direcionado a um e-mail
  note        String?  // referência interna (ex.: nome da loja/contato)
  // status: pending | used | revoked | expired
  status      String   @default("pending")
  lodgeId     String?  // preenchido quando o convite é consumido
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model AuditLog {
  id           String   @id @default(cuid())
  lodgeId      String
  userId       String?
  action       String
  entity       String
  entityId     String
  before       String?
  after        String?
  createdAt    DateTime @default(now())

  lodge        Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Session {
  id        String   @id @default(cuid())
  lodgeId   String
  title     String
  date      DateTime
  type      String   @default("ordinary")
  grade     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge      Lodge       @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  lodgeId   String
  sessionId String
  memberId  String
  status    String   @default("present")
  notes     String?
  createdAt DateTime @default(now())

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([lodgeId])
}

model Office {
  id        String   @id @default(cuid())
  lodgeId   String
  riteId    String?
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge        Lodge          @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  rite         Rite?          @relation(fields: [riteId], references: [id], onDelete: SetNull)
  memberOffices MemberOffice[]
}

model Rite {
  id        String   @id @default(cuid())
  lodgeId   String
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  members   Member[]
  offices   Office[]
}

model Term {
  id        String   @id @default(cuid())
  lodgeId   String
  title     String
  startDate DateTime
  endDate   DateTime?
  status    String   @default("active")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge        Lodge          @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  memberOffices MemberOffice[]
  cashCloses   CashClose[]
}

model MemberOffice {
  id        String   @id @default(cuid())
  lodgeId   String
  memberId  String
  officeId  String
  termId    String
  createdAt DateTime @default(now())

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  office    Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([memberId, officeId, termId])
  @@index([lodgeId])
}

model CashClose {
  id          String   @id @default(cuid())
  lodgeId     String
  termId      String
  closedAt    DateTime @default(now())
  totalReceivables Float  @default(0)
  totalPayables    Float  @default(0)
  totalPayments    Float  @default(0)
  netBalance       Float  @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  lodge       Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([lodgeId, termId])
}

model Power {
  id        String   @id @default(cuid())
  lodgeId   String
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  members   Member[]
}

// Plano de contas da loja (categorias de receita/despesa). Semeado por padrão
// com as contas típicas de uma loja maçônica (captações, taxas de grau, aluguel...).
model ChartAccount {
  id        String   @id @default(cuid())
  lodgeId   String
  code      String
  name      String
  type      String   // REVENUE | EXPENSE
  category  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)
  accounts  Account[]

  @@unique([lodgeId, code])
}

// RBAC persistido por loja: matriz papel × recurso × ação.
// Substitui o roleMap fixo em código — cada loja pode ajustar suas permissões.
// Se uma loja não tiver linhas, o sistema usa os padrões de src/lib/rbac.ts (DEFAULT_POLICY).
model RolePermission {
  id        String   @id @default(cuid())
  lodgeId   String
  role      String   // admin | venerable | treasurer | secretary | member
  resource  String   // members | documents | messages | accounts | portal
  action    String   // read | write
  allowed   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge     Lodge    @relation(fields: [lodgeId], references: [id], onDelete: Cascade)

  @@unique([lodgeId, role, resource, action])
  @@index([lodgeId])
}

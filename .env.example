# ===========================================================================
# Sigma Horus — variáveis de ambiente (exemplo). Copie para .env e preencha.
# NUNCA commitar o .env real (está no .gitignore).
# ===========================================================================

# --- Stripe (assinatura da plataforma — loja paga o SaaS) ---
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUB_KEY=pk_test_xxx
# gerado por: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Banco (PostgreSQL no Railway) ---
# superuser: migrations, login, onboarding, webhook Stripe (bypassa RLS)
DATABASE_URL=postgresql://postgres:senha@reseau.proxy.rlwy.net:PORTA/railway
# role sigma_app (NOBYPASSRLS): runtime de tenant, RLS aplicado via withTenant()
APP_DATABASE_URL=postgresql://sigma_app:senha@reseau.proxy.rlwy.net:PORTA/railway

# --- Auth.js (next-auth v5) ---
AUTH_SECRET=gerar_com_openssl_rand_base64_32

# --- Asaas (gateway de boleto/PIX — membro paga a loja) ---
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://api.asaas.com/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
# Token configurado no painel do Asaas para autenticar o webhook (header asaas-access-token).
# Se vazio, o webhook aceita qualquer chamada (ok p/ sandbox; defina em produção).
ASAAS_WEBHOOK_TOKEN=

# --- Cloudflare R2 (Centro de Documentos — storage real, S3-compatible) ---
# Conta: charlesvsouza@hotmail.com / account df7ed7eaafd41d7d0da2105f603099ae
# Bucket: sygmahorus-documents (região ENAM)
# Credenciais S3 = token R2 com escopo "Object Read & Write" no bucket.
# Gere em: Cloudflare Dashboard > R2 > Manage R2 API Tokens (ou via API /tokens).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sygmahorus-documents
R2_ENDPOINT=https://df7ed7eaafd41d7d0da2105f603099ae.r2.cloudflarestorage.com
# URL pública para "Abrir arquivo". ATENÇÃO: o endpoint S3 acima NÃO é navegável.
# Use um domínio público r2.dev/custom OU (recomendado p/ LGPD) presigned GET URLs.
NEXT_PUBLIC_STORAGE_PUBLIC_URL=
